build/                  # Wszystkie pliki CMake, pliki .o, .a, .so i binaria
build
bin/                    # Czasami binaria lądują tutaj
lib/                    # Skompilowane biblioteki statyczne
*.out                   # Domyślne pliki wyjściowe kompilatora
*.exe
*.app

*.i                     # Pliki pośrednie CUDA
*.ii
*.gpu
*.ptx                   # Wygenerowany kod asemblera GPU
*.fatbin
*.d                     # Pliki zależności (dependency files)
compute_prof_log.txt    # Logi profilera NVIDIA

.vscode/                # Ustawienia lokalne edytora
.idea/                  # Jeśli używasz CLion / IntelliJ
*.swp                   # Pliki tymczasowe Vima
.DS_Store               # Macowe śmieci

extern/*/.build/

data/                   # Tutaj trzymaj zbiory danych (MNIST, CIFAR itp.)
models/*.pth            # Wagi modeli (PyTorch)
models/*.onnx           # Modele wyeksportowane
*.log                   # Logi z treningu
node_modules/           # Jeśli użyjesz jakichś narzędzi JS do wizualizacji

__pycache__/
*.pyc
.ipynb_checkpoints/     # Notatniki Jupyter